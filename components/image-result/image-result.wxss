.result-card {
  background: #fff;
  border-radius: 24rpx;
  padding: 32rpx;
  margin-top: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.08);
}

.section-label {
  font-size: 24rpx;
  font-weight: 500;
  color: #64748b;
  margin-bottom: 20rpx;
  letter-spacing: 0.05em;
}

.result-image {
  width: 100%;
  height: 480rpx;
  border-radius: 16rpx;
  background: #f8fafc;
}

.result-actions {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 24rpx;
}

.btn-secondary,
.btn-primary {
  flex: 1;
  height: 88rpx;
  padding: 0;
  margin: 0;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 28rpx;
  border-radius: 16rpx;
  line-height: 1;
  box-sizing: border-box;
}

.btn-secondary::after,
.btn-primary::after {
  border: none;
}

.btn-secondary {
  background: #f1f5f9;
  color: #1e293b;
}

.btn-primary {
  background: #6366f1;
  color: #fff;
}
